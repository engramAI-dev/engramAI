# @sentry/nextjs 8.x peerDependencies don't list next@16 yet, but the SDK
# works at runtime. legacy-peer-deps relaxes the strict resolver so npm
# install / npm ci work without a per-call --legacy-peer-deps flag in
# Vercel, GitHub Actions, and local dev.
#
# Drop this file when @sentry/nextjs releases a version with next@^16
# in peerDependencies.
legacy-peer-deps=true
