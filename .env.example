# App
APP_ENV=development
SECRET_KEY=change-me-in-production
# Fernet key for encrypting secrets at rest (GitHub token). Leave blank in
# local dev (plaintext passthrough); REQUIRED in production. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://engram:engram@localhost:5432/engram

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub OAuth (free — create at GitHub > Settings > Developer Settings > OAuth Apps)
# Callback URL: http://localhost:8000/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Notion OAuth (create at notion.so/profile/integrations → Public integration)
# Redirect URI: http://localhost:8000/api/providers/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/providers/notion/callback

# Frontend URL (for post-auth redirect)
FRONTEND_URL=http://localhost:3000

# LLM (configurable — "gemini" or "anthropic")
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=
# To switch to Claude: set LLM_PROVIDER=anthropic and LLM_MODEL accordingly
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-20250514

# Embeddings (runs locally via sentence-transformers, no API key needed)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIMENSION=768

# CORS
# CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
