# App
APP_ENV=development
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://engram:engram@localhost:5432/engram

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub OAuth (free — create at GitHub > Settings > Developer Settings > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Frontend URL (for post-auth redirect)
FRONTEND_URL=http://localhost:3000

# LLM (D45: configurable — "gemini" or "anthropic")
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=
# To switch to Claude: set LLM_PROVIDER=anthropic and LLM_MODEL accordingly
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-20250514

# Embeddings (D44: runs locally via sentence-transformers, no API key needed)
EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code
# EMBEDDING_DIMENSION=768

# Notion (optional — only needed for Notion ingestion)
# NOTION_API_KEY=

# CORS
# CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
